# REQWISE - Environment Configuration

# Backend API Server Port
PORT=5000

# MongoDB Connection String
# For local development: mongodb://127.0.0.1:27017/reqwise
MONGODB_URI=mongodb://127.0.0.1:27017/reqwise

# JSON Web Token (JWT) Secret Key for Authentication
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters

# Node Environment Mode (development | production | test)
NODE_ENV=development
